{
  "name": "hot-tub-companion-api",
  "version": "1.0.0",
  "description": "Hot Tub Companion backend API",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "nodemon --exec ts-node src/server.ts",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "seed": "knex seed:run",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/__tests__/maintenanceSchedule.test.ts src/__tests__/filterMaintenancePlanner.test.ts src/__tests__/subscriptionHandoff.test.ts",
    "docs:inventory": "node scripts/generateApiInventory.js",
    "docs:usage": "node scripts/generateUsageIndex.js",
    "docs:openapi": "node scripts/generateOpenApi.js",
    "docs:generate": "npm run docs:inventory && npm run docs:usage && npm run docs:openapi",
    "docs:check": "npm run docs:generate && node scripts/checkDocsCoverage.js",
    "docs:governance": "npm run docs:check && npm --prefix ../docs run reference:refresh",
    "verify:storefront-gid": "node scripts/verify-storefront-variant-gid.mjs"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "@types/sanitize-html": "^2.16.1",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "expo-server-sdk": "^3.10.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.2.0",
    "firebase-admin": "^12.6.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.0",
    "pg": "^8.12.0",
    "sanitize-html": "^2.17.2",
    "stripe": "^17.7.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.9.0",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.1.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
