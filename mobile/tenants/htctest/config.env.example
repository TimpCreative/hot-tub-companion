# Copy to config.env and fill in real values. config.env is gitignored.
# Get tenant API key from Super Admin dashboard.
# Get Firebase keys from Firebase Console → Project Settings → Your apps.

TENANT=htctest
API_URL=https://api.hottubcompanion.com
TENANT_API_KEY=your_tenant_api_key
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
